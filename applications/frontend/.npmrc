# save-exact: when running `npm install <pkg>`, write the exact version
#   to package.json (e.g., "vue": "3.5.33") instead of the default caret
#   range ("vue": "^3.5.30"). This project pins direct dependencies
#   exactly so package.json reflects what's actually installed; without
#   this, future `npm install` invocations would re-introduce ranges and
#   silently erode the convention.
#
# engine-strict: convert the package.json `engines` field's warnings
#   into hard errors. If the running Node version doesn't satisfy
#   `engines.node`, `npm install` refuses to proceed instead of warning
#   and continuing. Surfaces version mismatches immediately rather than
#   manifesting as cryptic build failures later.
save-exact=true
engine-strict=true
