#!/usr/bin/env bash
set -Eeuo pipefail

# Run a locally built image with the repo's default container-to-host database wiring.
#
# Conventions:
# - Run this from an application directory that already has a built image.
# - Default image tag is "<current-directory>:latest".
# - Default container name is "<current-directory>".
# - Default host port is 8080.
# - DB_HOST defaults to host.docker.internal so the containerized app can
#   connect back to the shared local Postgres started by "compose up".
#
# Usage:
#   run-image
#   run-image backend:latest
#   run-image backend:latest 8081
#   DB_HOST=192.168.1.50 run-image

image_name="${1:-$(basename "$PWD"):latest}"
container_name="${CONTAINER_NAME:-$(basename "$PWD")}"
host_port="${2:-8080}"
db_host="${DB_HOST:-host.docker.internal}"

echo "Running Docker image '$image_name' as container '$container_name' on http://localhost:${host_port}"
docker run --rm \
  --name "${container_name}" \
  --add-host=host.docker.internal:host-gateway \
  -p "${host_port}:8080" \
  -e "DB_HOST=${db_host}" \
  "$image_name"
